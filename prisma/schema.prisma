generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  name             String?
  stripeCustomerId String?
  createdAt        DateTime  @default(now())
  bookings         Booking[] @relation("studentBookings")
}

model Teacher {
  id                 String  @id
  name               String
  email              String  @unique
  subject            String
  password           String
  mustChangePassword Boolean @default(true)

  bookings            Booking[]            @relation("teacherBookings") // FIX
  passwordResetTokens PasswordResetToken[]

  chat Chat[]
}

model Student {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Booking {
  id                     String   @id @default(uuid())
  studentId              String
  teacherId              String
  start                  DateTime
  end                    DateTime
  priceCents             Int
  currency               String   @default("eur")
  status                 String   @default("pending")
  stripeCustomerId       String?
  stripePaymentMethodId  String?
  stripeSetupIntentId    String?
  stripePaymentIntentId  String?
  createdAt              DateTime @default(now())

  student User    @relation("studentBookings", fields: [studentId], references: [id])
  teacher Teacher @relation("teacherBookings", fields: [teacherId], references: [id], onDelete: Cascade)
}



model TeacherApplication {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  subject   String?
  letter    String?
  filePath  String?
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  expiresAt DateTime
}

model Chat {
  id           String  @id @default(uuid())
  teacherId    String
  studentEmail String
  bookingId    String?

  teacher  Teacher       @relation(fields: [teacherId], references: [id])
  messages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(uuid())
  chatId    String
  sender    String
  text      String
  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id])
}
