// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

/**
 * Österreich – Schultypen (feingranular)
 * AHS: Unterstufe 1–4, Oberstufe 1–4
 * BHS: Oberstufe 1–5
 */
enum SchoolTrack {
  AHS
  BHS
}

enum SchoolLevel {
  UNTERSTUFE
  OBERSTUFE
}

/**
 * Konkrete Schulformen/Schulzweige
 */
enum SchoolForm {
  // --- AHS ---
  AHS_GYMNASIUM
  AHS_REALGYMNASIUM
  AHS_WK_REALGYMNASIUM
  AHS_BORG
  AHS_SCHWERPUNKT

  // --- BHS ---
  BHS_HTL
  BHS_HAK
  BHS_HLW
  BHS_MODE
  BHS_KUNST_GESTALTUNG
  BHS_TOURISMUS
  BHS_SOZIALPAED
  BHS_LAND_FORST

  OTHER
}

/**
 * Schüler
 */
model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  name             String?
  role             String   @default("student")
  stripeCustomerId String?
  createdAt        DateTime @default(now())

  // ✅ Schul-Infos (NEU)
  schoolTrack SchoolTrack?
  schoolForm  SchoolForm?
  schoolName  String?
  level       SchoolLevel?
  grade       Int?

  bookings Booking[] @relation("studentBookings")
}

/**
 * Lehrer
 */
model Teacher {
  id    String @id @default(uuid())
  name  String
  email String @unique

  // ⚠️ Übergang: im UI/API ist subject noch String.
  // TeachingOffer ist die "richtige" Logik, subject bleibt erstmal für Kompatibilität.
  subject String

  password           String
  mustChangePassword Boolean @default(true)

  bookings            Booking[]            @relation("teacherBookings")
  passwordResetTokens PasswordResetToken[]
  chat                Chat[]
  availabilities      Availability[]

  // ✅ NEU: Angebote des Lehrers
  offers TeachingOffer[]
}

/**
 * Fächer-Lookup
 */
model Subject {
  id   String @id @default(uuid())
  name String @unique

  offers TeachingOffer[]
}

/**
 * Lehrer-Angebote
 */
model TeachingOffer {
  id String @id @default(uuid())

  teacherId String
  subjectId String

  schoolTrack SchoolTrack
  schoolForm  SchoolForm
  level       SchoolLevel

  minGrade Int
  maxGrade Int

  createdAt DateTime @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  // ✅ NEU: Gegenrelation (WICHTIG)
  availabilities Availability[]

  @@unique([teacherId, subjectId, schoolForm, level, minGrade, maxGrade])
  @@index([teacherId])
  @@index([subjectId])
  @@index([schoolForm, level, minGrade, maxGrade])
}

/**
 * Buchungen
 */
model Booking {
  id                    String   @id @default(uuid())
  studentId             String
  teacherId             String
  start                 DateTime
  end                   DateTime
  priceCents            Int
  currency              String   @default("eur")
  status                String   @default("pending")
  stripeCustomerId      String?
  stripePaymentMethodId String?
  stripeSetupIntentId   String?
  stripePaymentIntentId String?
  createdAt             DateTime @default(now())
  note                  String?

  student User    @relation("studentBookings", fields: [studentId], references: [id])
  teacher Teacher @relation("teacherBookings", fields: [teacherId], references: [id], onDelete: Cascade)
}

/**
 * Lehrerbewerbungen
 */
model TeacherApplication {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  subject   String?
  letter    String?
  filePath  String?
  createdAt DateTime @default(now())
}

/**
 * Reset Tokens
 */
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  expiresAt DateTime
}

/**
 * Chat
 */
model Chat {
  id           String  @id @default(uuid())
  teacherId    String
  studentEmail String
  bookingId    String?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  messages ChatMessage[]
  teacher  Teacher       @relation(fields: [teacherId], references: [id])
}

model ChatMessage {
  id        String   @id @default(uuid())
  chatId    String
  sender    String
  text      String
  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id])
}

model Availability {
  id        String   @id @default(uuid())
  teacherId String
  date      DateTime
  start     String
  end       String

  // 🔗 Slot gehört zu einem konkreten Angebot
  offerId String?
  offer   TeachingOffer? @relation(fields: [offerId], references: [id], onDelete: SetNull)

  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@index([teacherId])
  @@index([offerId])
}
