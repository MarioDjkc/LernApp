generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Teacher {
  id                 String   @id
  name               String
  email              String   @unique
  subject            String
  password           String
  mustChangePassword Boolean  @default(true)
  bookings           Booking[]
  resetTokens        PasswordResetToken[]
}

model Booking {
  id         String   @id @default(cuid())
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id])
  name       String
  createdAt  DateTime @default(now())
}

model TeacherApplication {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  subject   String?
  letter    String?
  filePath  String?
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  token      String   @unique
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id])
  expiresAt  DateTime
}
