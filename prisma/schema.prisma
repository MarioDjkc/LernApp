generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Teacher {
  id                 String  @id
  name               String
  email              String  @unique
  subject            String
  password           String
  mustChangePassword Boolean @default(true)

  bookings            Booking[]
  passwordResetTokens PasswordResetToken[]
}

model Student {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}


model Booking {
  id           String   @id @default(cuid())
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id])

  studentName  String
  studentEmail String
  subject      String?

  startsAt     DateTime
  endsAt       DateTime?
  note         String?

  status       String   @default("REQUESTED")
  createdAt    DateTime @default(now())
}

model TeacherApplication {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  subject   String?
  letter    String?
  filePath  String?
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  expiresAt DateTime
}
